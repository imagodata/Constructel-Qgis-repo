    &lt;strong>🏛️ Structures:&lt;/strong> [% COALESCE("total_structures", 0) %]&#xd;
  &lt;/p>&#xd;
  &lt;p style="margin: 4px 0; color: #14532d; font-size: 12px;">&#xd;
    &lt;strong>📡 Câbles:&lt;/strong> [% COALESCE("total_cables", 0) %] | &#xd;
    &lt;strong>💡 Fibres:&lt;/strong> [% COALESCE("fiber_capacity", 0) %]&#xd;
  &lt;/p>&#xd;
  &lt;p style="margin: 4px 0; color: #14532d; font-size: 12px;">&#xd;
    &lt;strong>📈 Avancement:&lt;/strong> [% COALESCE("dp_progress_percentage", '0') %]%&#xd;
  &lt;/p>&#xd;
  [% IF "actual_start_date" IS NOT NULL OR "planned_end_date" IS NOT NULL %]&#xd;
