  <mapTip enabled="1">&lt;div style="font-family: Arial, sans-serif; padding: 10px; max-width: 350px; background: linear-gradient(135deg, #f0fdf4, #dcfce7); border-radius: 10px; border: 2px solid #22c55e;">&#xd;
  &lt;h3 style="margin: 0 0 10px 0; color: #166534; font-size: 16px;">🌐 [% COALESCE("name", 'Zone POP #' || "id") %]&lt;/h3>&#xd;
  &lt;p style="margin: 4px 0; color: #14532d; font-size: 12px;">&#xd;
    &lt;strong>🏷️ Code:&lt;/strong> [% COALESCE("code", 'N/A') %] | &#xd;
    &lt;strong>Status:&lt;/strong> [% COALESCE("status", 'N/A') %]&#xd;
  &lt;/p>&#xd;
  &lt;p style="margin: 4px 0; color: #14532d; font-size: 12px;">&#xd;
    &lt;strong>� HP:&lt;/strong> [% COALESCE("dp_sum_hp", 0) %] | &#xd;
    &lt;strong>🏛️ Structures:&lt;/strong> [% COALESCE("total_structures", 0) %]&#xd;
  &lt;/p>&#xd;
  &lt;p style="margin: 4px 0; color: #14532d; font-size: 12px;">&#xd;
    &lt;strong>📡 Câbles:&lt;/strong> [% COALESCE("total_cables", 0) %] | &#xd;
    &lt;strong>💡 Fibres:&lt;/strong> [% COALESCE("fiber_capacity", 0) %]&#xd;
  &lt;/p>&#xd;
  &lt;p style="margin: 4px 0; color: #14532d; font-size: 12px;">&#xd;
    &lt;strong>📈 Avancement:&lt;/strong> [% COALESCE("dp_progress_percentage", '0') %]%&#xd;
  &lt;/p>&#xd;
  [% IF "actual_start_date" IS NOT NULL OR "planned_end_date" IS NOT NULL %]&#xd;
  &lt;hr style="border: 0; border-top: 1px solid #86efac; margin: 8px 0;">&#xd;
  &lt;p style="margin: 2px 0; color: #15803d; font-size: 11px;">&#xd;
    [% IF "actual_start_date" IS NOT NULL %]&lt;strong>📅 Début:&lt;/strong> [% format_date("actual_start_date", 'dd/MM/yyyy') %][% END %]&#xd;
    [% IF "planned_end_date" IS NOT NULL %] | &lt;strong>🏁 Fin prévue:&lt;/strong> [% format_date("planned_end_date", 'dd/MM/yyyy') %][% END %]&#xd;
  &lt;/p>&#xd;
  [% END %]&#xd;
  [% IF "doc_count" > 0 %]&#xd;
  &lt;p style="margin: 4px 0; color: #1565C0; font-size: 12px; font-weight: bold;">&#xd;
    [% "doc_count" %] document(s)&#xd;
  &lt;/p>&#xd;
  [% END %]&#xd;
