  <mapTip enabled="1">&lt;div style="font-family: Arial, sans-serif; padding: 10px; max-width: 350px; background: linear-gradient(135deg, #f0fdf4, #dcfce7); border-radius: 10px; border: 2px solid #22c55e;">&#xd;
  &lt;h3 style="margin: 0 0 10px 0; color: #166534; font-size: 16px;">🌐 [% COALESCE("name", 'Zone POP #' || "id") %]&lt;/h3>&#xd;
  &lt;p style="margin: 4px 0; color: #14532d; font-size: 12px;">&#xd;
    &lt;strong>🏷️ Code:&lt;/strong> [% COALESCE("code", 'N/A') %] | &#xd;
    &lt;strong>Status:&lt;/strong> [% COALESCE("status", 'N/A') %]&#xd;
  &lt;/p>&#xd;
