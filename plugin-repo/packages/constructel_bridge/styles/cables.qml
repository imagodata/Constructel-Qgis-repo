  <mapTip enabled="1">&lt;div style="font-family:Arial,sans-serif;font-size:11px;padding:6px;background:#f0f8ff;border:1px solid #6495ed;border-radius:4px;min-width:220px;">&#xd;
&lt;div style="font-weight:bold;font-size:13px;color:#333;margin-bottom:4px;">&#xd;
  [% CASE &#xd;
    WHEN "cable_type" = 'BACKBONE' THEN '🟣'&#xd;
    WHEN "cable_type" = 'FEEDER' THEN '🟠'&#xd;
    WHEN "cable_type" = 'PRIM_DISTRIBUTION' THEN '🟡'&#xd;
    WHEN "cable_type" = 'DISTRIBUTION' THEN '🟢'&#xd;
    WHEN "cable_type" = 'DROP' THEN '⚪'&#xd;
    ELSE '📶'&#xd;
  END %] [% coalesce("nomenclature", "name", "cable_type") %]&#xd;
&lt;/div>&#xd;
&lt;table style="width:100%;border-collapse:collapse;">&#xd;
  &lt;tr>&lt;td style="color:#666;">📶 Type:&lt;/td>&lt;td style="font-weight:500;">[% "cable_type" %]&lt;/td>&lt;/tr>&#xd;
  &lt;tr>&lt;td style="color:#666;">🔄 Status:&lt;/td>&lt;td style="font-weight:500;">[%&#xd;
    CASE "status"&#xd;
      WHEN 'CP' THEN '📋 Construction Planned'&#xd;
      WHEN 'CONSTRUCTED' THEN '🔵 Constructed'&#xd;
      ELSE "status"&#xd;
    END %]&lt;/td>&lt;/tr>&#xd;
  [% IF "breakout_letter" IS NOT NULL %]&#xd;
  &lt;tr>&lt;td style="color:#666;">🅰️ Breakout:&lt;/td>&lt;td>[% "breakout_letter" %]&lt;/td>&lt;/tr>&#xd;
  [% END %]&#xd;
  &lt;tr>&lt;td style="color:#666;">🔢 Fibres:&lt;/td>&lt;td>[% "fiber_count" %]&lt;/td>&lt;/tr>&#xd;
  &lt;tr>&lt;td style="color:#666;">📏 Longueur:&lt;/td>&lt;td>[% round("length_m", 1) %] m&lt;/td>&lt;/tr>&#xd;
  [% IF "doc_count" > 0 %]&#xd;
  &lt;tr>&lt;td style="color:#666;">Documents:&lt;/td>&lt;td style="font-weight:500;color:#1565C0;">[% "doc_count" %] doc(s)&lt;/td>&lt;/tr>&#xd;
  [% END %]&#xd;
&lt;/table>&#xd;
&lt;div style="margin-top:4px;padding-top:4px;border-top:1px solid #ddd;font-size:10px;text-align:center;color:#888;">&#xd;
  [% IF "blowing_date" IS NOT NULL %]💨 [% format_date("blowing_date", 'dd/MM') %] [% END %]&#xd;
  [% IF "splice_date" IS NOT NULL %]→ 🔵 [% format_date("splice_date", 'dd/MM') %] [% END %]&#xd;
  [% IF "measurement_date" IS NOT NULL %]→ 🟢 [% format_date("measurement_date", 'dd/MM') %] [% END %]&#xd;
  [% IF "validation_date" IS NOT NULL %]→ ✅ [% format_date("validation_date", 'dd/MM') %] [% END %]&#xd;
&lt;/div>&#xd;
&lt;/div></mapTip>
