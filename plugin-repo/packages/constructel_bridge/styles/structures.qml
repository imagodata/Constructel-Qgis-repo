  <mapTip enabled="1">&lt;div style="font-family:Arial,sans-serif;font-size:11px;padding:6px;background:#fff;border:1px solid #ccc;border-radius:4px;min-width:180px;">&#xd;
&lt;div style="font-weight:bold;font-size:13px;color:#333;margin-bottom:4px;">&#xd;
  [% CASE &#xd;
    WHEN "structure_type" = 'Cabinet' THEN '🏢'&#xd;
    WHEN "structure_type" = 'Access Point' THEN '📡'&#xd;
    WHEN "structure_type" = 'Drop Connection Point' THEN '🔌'&#xd;
    WHEN "structure_type" = 'POC facade' THEN '🏠'&#xd;
    WHEN "structure_type" = 'Manhole' THEN '🕳️'&#xd;
    WHEN "structure_type" = 'POC underground' THEN '⬇️'&#xd;
    WHEN "structure_type" = 'Virtual' THEN '👻'&#xd;
    WHEN "structure_type" = 'Junction Point' THEN '💎'&#xd;
    ELSE '📍'&#xd;
  END %] [% coalesce("nomenclature", "label", "structure_type") %]&#xd;
&lt;/div>&#xd;
&lt;table style="width:100%;border-collapse:collapse;">&#xd;
  &lt;tr>&lt;td style="color:#666;">📦 Type:&lt;/td>&lt;td style="font-weight:500;">[% "structure_type" %]&lt;/td>&lt;/tr>&#xd;
  &lt;tr>&lt;td style="color:#666;">🔄 Status:&lt;/td>&lt;td style="font-weight:500;">[%&#xd;
    CASE "status"&#xd;
      WHEN 'CP' THEN '📋 Construction Planned'&#xd;
      WHEN 'CONSTRUCTED' THEN '🔵 Constructed'&#xd;
      WHEN 'SP' THEN '🟣 Splicing Planned'&#xd;
      WHEN 'SPLICED' THEN '🔮 Spliced'&#xd;
      WHEN 'MP' THEN '🔹 Measurement Planned'&#xd;
      WHEN 'MEASURED' THEN '📏 Measured'&#xd;
      WHEN 'AS_BUILT' THEN '✅ As-Built'&#xd;
      WHEN 'TODO' THEN '🔴 TODO'&#xd;
      WHEN 'PARTIALLY_SPLICED' THEN '🟠 Partially Spliced'&#xd;
      ELSE "status"&#xd;
    END %]&lt;/td>&lt;/tr>&#xd;
  [% IF "nearest_address" IS NOT NULL %]&#xd;
  &lt;tr>&lt;td style="color:#666;">🏠 Adresse:&lt;/td>&lt;td>[% "nearest_address" %]&lt;/td>&lt;/tr>&#xd;
  [% END %]&#xd;
  [% IF "fiber_capacity" IS NOT NULL %]&#xd;
  &lt;tr>&lt;td style="color:#666;">🔢 Fibres:&lt;/td>&lt;td>[% "fiber_capacity" %]&lt;/td>&lt;/tr>&#xd;
  [% END %]&#xd;
  [% IF "is_splice_closure" = true %]&#xd;
  &lt;tr>&lt;td colspan="2" style="color:#9370DB;">🔀 Splice Closure&lt;/td>&lt;/tr>&#xd;
  [% END %]&#xd;
  [% IF "doc_count" > 0 %]&#xd;
  &lt;tr>&lt;td style="color:#666;">Documents:&lt;/td>&lt;td style="font-weight:500;color:#1565C0;">[% "doc_count" %] doc(s)&lt;/td>&lt;/tr>&#xd;
  [% END %]&#xd;
&lt;/table>&#xd;
&lt;/div></mapTip>
